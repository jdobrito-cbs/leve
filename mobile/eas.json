{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_LEVE_SERVER_URL": "https://www.levemobile.com.br"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_LEVE_SERVER_URL": "https://www.levemobile.com.br"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_LEVE_SERVER_URL": "https://www.levemobile.com.br"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
