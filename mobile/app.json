{
  "expo": {
    "name": "Leve",
    "slug": "leve",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "leve",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.leve.mobile",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "O Leve importa peso, passos, sono, frequência cardíaca e composição corporal do Apple Saúde apenas quando você autoriza, para exibir seu progresso no app. Os dados ficam somente no seu aparelho.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.leve.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EFF6FF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-font",
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "@kingstinct/react-native-healthkit",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Leve usa suas fotos apenas quando você escolhe uma imagem para identificar alimentos.",
          "cameraPermission": "O Leve usa a câmera apenas quando você fotografa uma refeição para identificar alimentos."
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-sensors",
        {
          "motionPermission": "O Leve usa o movimento do aparelho apenas para animar a água dos gráficos."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e26c1ba7-dafc-4b2f-8af3-b3a71f7aa222"
      }
    }
  }
}
