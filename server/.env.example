# ── Análise de foto (obrigatório) ─────────────────────────────────────────────
# Qualquer serviço compatível com a API OpenAI (SEM /chat/completions no final).
# Exemplo com OpenRouter:
HUB_BASE_URL=https://openrouter.ai/api/v1
# Chave secreta — fica SÓ aqui, nunca no app.
HUB_API_KEY=cole-aqui-a-sua-chave-do-openrouter
# Escolha um modelo COM VISÃO. Os gratuitos mudam com o tempo — confira em openrouter.ai/models:
HUB_MODEL=qwen/qwen2.5-vl-32b-instruct:free

# ── Painel de parceiros (/admin) ──────────────────────────────────────────────
# Código de acesso do painel. Invente um valor longo e guarde só com você.
ADMIN_TOKEN=troque-por-um-codigo-longo-e-secreto

# ── Opcional ──────────────────────────────────────────────────────────────────
# Token simples exigido do app no scan (header x-leve-app).
APP_TOKEN=
PORT=3333
# Pasta dos dados locais (chaves de parceiro sem banco). Padrão ./data
#DATA_DIR=./data

# Contas/backup — sem estes, o servidor sobe com scan + painel de parceiros.
# Segredo dos JWT (gere um aleatório longo, ex.: openssl rand -hex 32)
JWT_SECRET=
# Senha do Postgres do docker-compose (DATABASE_URL é montada automaticamente)
POSTGRES_PASSWORD=
