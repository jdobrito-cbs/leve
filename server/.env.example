# URL base do AI Hub (formato OpenAI-compatível; SEM /chat/completions no final)
HUB_BASE_URL=https://seu-ai-hub.exemplo.com/v1
# Chave secreta do AI Hub — fica SÓ aqui, nunca no app
HUB_API_KEY=troque-me
# Modelo de visão a usar
HUB_MODEL=gpt-4o
# Opcional: token simples exigido do app (header x-leve-app)
APP_TOKEN=
PORT=3333

# Contas/backup — sem estes, o servidor sobe só com o scan
# Segredo dos JWT (gere um aleatório longo, ex.: openssl rand -hex 32)
JWT_SECRET=
# Senha do Postgres do docker-compose (DATABASE_URL é montada automaticamente)
POSTGRES_PASSWORD=
