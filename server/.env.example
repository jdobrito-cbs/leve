# ── Análise de foto (obrigatório) ─────────────────────────────────────────────
# Qualquer serviço compatível com a API OpenAI (SEM /chat/completions no final).
# A chave secreta fica SÓ aqui, nunca no app.
#
# Opção A — Google Gemini direto (chave em aistudio.google.com; nível gratuito bom):
HUB_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
HUB_API_KEY=cole-aqui-a-sua-chave-do-google-ai-studio
HUB_MODEL=gemini-2.5-flash
#
# Opção B — OpenRouter (vários modelos; gratuitos mudam — confira openrouter.ai/models):
#HUB_BASE_URL=https://openrouter.ai/api/v1
#HUB_API_KEY=cole-aqui-a-sua-chave-do-openrouter
#HUB_MODEL=qwen/qwen2.5-vl-32b-instruct:free

# ── Painel de parceiros (/painel) ─────────────────────────────────────────────
# Código de acesso do painel — MÍNIMO 16 caracteres (o servidor recusa subir com
# menos). Gere um forte: openssl rand -hex 24
ADMIN_TOKEN=troque-por-um-codigo-longo-e-secreto

# ── Opcional ──────────────────────────────────────────────────────────────────
# Token simples exigido do app no scan (header x-leve-app).
APP_TOKEN=
PORT=3333
# Pasta dos dados locais (chaves de parceiro/admins sem banco). Padrão ./data
#DATA_DIR=./data

# ── Produção (www.levemobile.com.br) ─────────────────────────────────────────
# Atrás de um proxy HTTPS (Caddy/Nginx), ligue para o rate limit enxergar o IP
# real de cada visitante (X-Forwarded-For) em vez do IP do proxy:
#TRUST_PROXY=1

# Senha do Postgres do docker-compose (DATABASE_URL é montada automaticamente)
POSTGRES_PASSWORD=
